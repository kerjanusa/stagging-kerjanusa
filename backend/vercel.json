{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": [
    "hnd1"
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.php"
    }
  ],
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4",
      "maxDuration": 60
    }
  }
}
