APP_NAME="KerjaNusa"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://kerjanusa-backend.vercel.app
FRONTEND_APP_URL=https://uat-kerjanusa.vercel.app
APP_STORAGE_PATH=/tmp/kerjanusa-storage

LOG_CHANNEL=stderr
LOG_LEVEL=error
LOG_SERVICE_LEVEL=info
LOG_SERVICE_DAYS=14

DB_CONNECTION=pgsql
DB_HOST=aws-0-your-region.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=
DB_SSLMODE=require
# Optional single-string alternative:
# DATABASE_URL=postgresql://postgres.your-project-ref:your-supabase-db-password@aws-0-your-region.pooler.supabase.com:5432/postgres

CACHE_DRIVER=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

MAIL_MAILER=log
# Untuk forgot/reset password via email sungguhan, ganti ke smtp dan isi kredensial mailer.
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@kerjanusa.com"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=uat-kerjanusa.vercel.app
CORS_ALLOWED_ORIGINS=https://uat-kerjanusa.vercel.app
