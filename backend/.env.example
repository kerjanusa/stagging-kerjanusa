APP_NAME="Pintarnya"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000
FRONTEND_APP_URL=http://localhost:5173

LOG_CHANNEL=single
LOG_LEVEL=debug
LOG_SERVICE_LEVEL=debug
LOG_SERVICE_DAYS=14

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=pintarnya_db
DB_USERNAME=pintarnya
DB_PASSWORD=pintarnya123
DB_SOCKET=/var/run/mysqld/mysqld.sock

# PostgreSQL / Supabase pooler example
# DB_CONNECTION=pgsql
# DB_HOST=aws-1-ap-northeast-1.pooler.supabase.com
# DB_PORT=5432
# DB_DATABASE=postgres
# DB_USERNAME=postgres.dmcjrfpnmituueygdvgv
# DB_PASSWORD=your-database-password
# DB_SSLMODE=require
# DATABASE_URL=postgresql://postgres.dmcjrfpnmituueygdvgv:your-database-password@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

MAIL_MAILER=log
# Untuk reset password sungguhan, ganti ke smtp lalu isi host/username/password.
# MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@pintarnya.com"
MAIL_FROM_NAME="${APP_NAME}"
PASSWORD_RESET_TRANSPORT=mail
PASSWORD_RESET_LOG_FALLBACK=false
BREVO_API_KEY=
BREVO_API_ENDPOINT=https://api.brevo.com/v3/smtp/email
BREVO_API_TIMEOUT=15

SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:8000
